  "version": "1.0.0",
  "description": "Professional landing page for JAYIDEVTECH - Software development services",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier \"src/**/*.{ts,vue,css}\" \"*.{js,cjs,mjs,json,html}\" --write",
    "format:check": "prettier \"src/**/*.{ts,vue,css}\" \"*.{js,cjs,mjs,json,html}\" --check",
    "check": "npm run type-check && npm run lint && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "jayidevtech",
    "landing-page",
    "tailwindcss",
    "flowbite"
